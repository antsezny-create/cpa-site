rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ─────────────────────────────────────────────
    //  HELPER FUNCTIONS
    // ─────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }


    // ─────────────────────────────────────────────
    //  CLIENT DOCUMENTS
    //  Path: documents/{clientUID}/{filename}
    //  - Clients can upload PDFs up to 20MB to their own folder only.
    //  - Clients can read and delete their own files.
    //  - Admins can read, write, and delete any file.
    // ─────────────────────────────────────────────
    match /documents/{clientUID}/{allPaths=**} {
      allow read:   if isAdmin() || (isSignedIn() && request.auth.uid == clientUID);
      allow create: if isAdmin() ||
        (isSignedIn() &&
          request.auth.uid == clientUID &&
          request.resource.size < 20 * 1024 * 1024 &&
          request.resource.contentType == 'application/pdf');
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == clientUID);
      allow update: if isAdmin();
    }


    // ─────────────────────────────────────────────
    //  PRACTITIONER FORM LIBRARY
    //  Path: practitioner-forms/{filename}
    //  - Admin only — form uploads from Forms & Schedules tab.
    // ─────────────────────────────────────────────
    match /practitioner-forms/{allPaths=**} {
      allow read, write: if isAdmin();
    }


    // ─────────────────────────────────────────────
    //  SAVED FILLED FORMS
    //  Path: saved-forms/{filename}
    //  - Admin only.
    // ─────────────────────────────────────────────
    match /saved-forms/{allPaths=**} {
      allow read, write: if isAdmin();
    }


    // ─────────────────────────────────────────────
    //  EVERYTHING ELSE — deny by default
    // ─────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }

  }
}
